<UserControl x:Class="GradientMap.Views.GradientEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:GradientMap.Localization"
             xmlns:ymmc="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             x:Name="root">
    <StackPanel>
        <Grid Height="22">
            <Rectangle Fill="{Binding GradientBrush}"
                       RadiusX="0" RadiusY="0"/>
            <Canvas x:Name="GradientCanvas"
                    Background="Transparent"
                    MouseLeftButtonDown="OnCanvasMouseLeftButtonDown">
                <Canvas.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                     RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="{x:Static loc:Texts.ExportAsGrdName}"
                                  Command="{Binding ExportAsGrdCommand}"/>
                        <MenuItem Header="{x:Static loc:Texts.ExportAsPngName}"
                                  Command="{Binding ExportAsPngCommand}"/>
                    </ContextMenu>
                </Canvas.ContextMenu>
            </Canvas>
        </Grid>

        <ItemsControl ItemsSource="{Binding Stops}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Height="26">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="26"/>
                        </Grid.ColumnDefinitions>

                        <ymmc:ColorPicker Grid.Column="0"
                                          Value="{Binding Color, Mode=TwoWay}"
                                          VerticalAlignment="Stretch"
                                          HorizontalAlignment="Stretch"/>

                        <Button Grid.Column="1"
                                Command="{Binding DataContext.DeleteStopCommand, ElementName=root}"
                                CommandParameter="{Binding}"
                                ToolTip="{x:Static loc:Texts.DeleteStopName}"
                                Padding="4">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"/>
                            </Button.Style>
                            <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z"
                                  Width="12" Height="12"
                                  Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
